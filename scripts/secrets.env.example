# ─────────────────────────────────────────────────────────────────────────────
# ProfitEngine v5 — Server secrets template
#
# USAGE:
#   1. Copy this file to ~/.profitengine-secrets on the SERVER (not in repo)
#   2. Fill in all values
#   3. chmod 600 ~/.profitengine-secrets
#   4. source ~/.profitengine-secrets && bash scripts/bootstrap-server.sh
#
# This file is a TEMPLATE — never commit the filled-in version.
# ─────────────────────────────────────────────────────────────────────────────

# Inference cascade — free AI tiers
GROQ_API_KEY=                        # https://console.groq.com
GEMINI_API_KEY=                      # https://aistudio.google.com/apikey

# GitHub content publishing
GITHUB_CONTENT_TOKEN=                # https://github.com/settings/tokens (repo scope)
GITHUB_CONTENT_OWNER=quantam101
GITHUB_CONTENT_REPO=content
GITHUB_CONTENT_BRANCH=main
GITHUB_CONTENT_DIR=posts

# Gmail digest alerts
GMAIL_USER=alreadyherellc@gmail.com
GMAIL_APP_PASSWORD=                  # https://myaccount.google.com/apppasswords
ALERT_EMAIL=stephen47@gmail.com

# n8n automation
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=             # choose a strong password

# Optional: Anthropic Claude (paid; only needed for complex tasks)
# ANTHROPIC_API_KEY=

# Optional: Dev.to publishing
# DEVTO_API_KEY=                     # https://dev.to/settings/extensions

# Optional: Affiliate link map (JSON)
# AFFILIATE_LINKS={"VPS hosting": "https://ref.url"}
