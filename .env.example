# Domain Configuration
# Set SITE_DOMAIN to your production domain before deploying.
# The Caddyfile and docker-compose.yml reference this variable.
SITE_DOMAIN=profitengine.alreadyherellc.com
ACME_EMAIL=ops@alreadyherellc.com

# Public URLs (auto-derived from SITE_DOMAIN in Caddyfile)
PUBLIC_SITE_URL=https://profitengine.alreadyherellc.com
COMMAND_CENTER_URL=https://app.profitengine.alreadyherellc.com

# Postgres
POSTGRES_DB=profitengine
POSTGRES_USER=profitengine
POSTGRES_PASSWORD=

# Runtime API (Python FastAPI — internal docker service URL or localhost)
RUNTIME_API_URL=http://runtime:8080
# Backend FastAPI (ProofPublish, distillation, enterprise) — internal service URL
# Set to https://backend.alreadyherellc.com in Vercel production env vars
BACKEND_API_URL=http://backend:8001
# Oracle API (Next.js command routing — set to http://web:3000 inside Docker)
ORACLE_API_URL=http://localhost:3000

# ── Inference cascade: Ollama (free) → Claude (key-gated) → stub ─────────────
#
# Tier 1 — Ollama local (free forever, runs on OCI A1 ARM CPU)
# After first deploy: docker compose exec ollama ollama pull llama3.1:8b
GMAOS_LOCAL_MODEL_ENABLED=true
GMAOS_LOCAL_MODEL_ENDPOINT=http://ollama:11434
GMAOS_LOCAL_MODEL_NAME=llama3.1:8b
GMAOS_LOCAL_MODEL_TIMEOUT=120
#
# Tier 2 — Anthropic Claude (key-gated fallback for complex tasks)
# Set directly on the server; never commit the real value.
# Variable name: ANTHROPIC_API_KEY  (set in server .env, not here)
#
# Complexity routing thresholds (0.0–1.0); defaults shown:
# GMAOS_THRESH_DETERMINISTIC=0.25
# GMAOS_THRESH_LOCAL_MODEL=0.70
# GMAOS_THRESH_CLAUDE=0.90

# n8n (keep private until auth is confirmed)
# N8N_HOST=n8n.yourdomain.com
# N8N_PROTOCOL=https
# N8N_PUBLIC_URL=https://n8n.yourdomain.com
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=
N8N_BASIC_AUTH_PASSWORD=

# ── Google OAuth (NextAuth) ───────────────────────────────────────────────
# 1. Go to console.cloud.google.com → APIs & Services → Credentials → Create OAuth 2.0 Client
# 2. Authorized redirect URI: https://profitengine-tau.vercel.app/api/auth/callback/google
# 3. Also add localhost:3000/api/auth/callback/google for local dev
# Variables (set in Vercel env vars, not here):
# GOOGLE_CLIENT_ID      — OAuth 2.0 Client ID
# GOOGLE_CLIENT_SECRET  — OAuth 2.0 Client Secret
# NEXTAUTH_SECRET       — run: openssl rand -base64 32
# NEXTAUTH_URL          — https://profitengine-tau.vercel.app  (or your custom domain)

# ── TokenForge LLM proxy (free, 50k tokens/month) ────────────────────────
# Multi-provider proxy (Anthropic, OpenAI, Groq, Gemini) — free tier
# Dashboard: https://app.tokenforge.io
# Variable: TOKENFORGE_API_KEY  (set in server .env + Vercel env vars, not here)
# Routes: GET/POST /api/tokenforge   POST /api/tokenforge-demo (cached 1hr)

# ── Free AI inference (set on server — not in repo) ───────────────────────
# Groq: 700+ tok/s, free tier — https://console.groq.com
# Variable: GROQ_API_KEY  (set in server .env, not here)
GMAOS_GROQ_MODEL=llama-3.3-70b-versatile
GMAOS_GROQ_TIMEOUT=60
#
# Gemini Flash: free, 1M context — https://aistudio.google.com
# Variable: GEMINI_API_KEY  (set in server .env, not here)
GMAOS_GEMINI_MODEL=gemini-1.5-flash
GMAOS_GEMINI_TIMEOUT=60

# ── Content publishing ────────────────────────────────────────────────────
# Dev.to: free — create account at https://dev.to, then key at https://dev.to/settings/extensions
# Variable: DEVTO_API_KEY  (set in server .env, not here)
# Sign up: https://dev.to/enter?state=new-user
#
# GitHub Pages content site
GITHUB_CONTENT_OWNER=quantam101
GITHUB_CONTENT_REPO=content
GITHUB_CONTENT_BRANCH=main
GITHUB_CONTENT_DIR=posts
# Variable: GITHUB_CONTENT_TOKEN  (set in server .env, not here)
# Live site: https://quantam101.github.io/content/

# ── Webhook endpoints (wired to alreadyherellc.com CMS) ───────────────────
# POST /api/webhooks/blog     — cross-post new articles to Dev.to + GitHub Pages
# POST /api/webhooks/traffic  — ingest GA/traffic events
# POST /api/webhooks/dispatch — service dispatch notifications
# Required: set this token in Vercel env vars AND in the already-here-llc dispatch config.
# Generate with: openssl rand -hex 32
# Variable: PROFITENGINE_WEBHOOK_TOKEN  (set in Vercel production env, not here)

# ── Vercel/Next.js env vars ───────────────────────────────────────────────
# Variable: GITHUB_CONTENT_TOKEN  (also set in Vercel env to avoid GitHub API rate limits)
# Variable: ORACLE_API_URL        (Vercel default: http://localhost:3000 — falls back gracefully)
# Variable: NEXT_PUBLIC_SITE_URL  (Vercel default: https://profitengine.alreadyherellc.com)

# ── Affiliate links (JSON keyword→URL map) ────────────────────────────────
# Add your affiliate links here once your accounts are approved.
# Example: AFFILIATE_LINKS={"VPS hosting": "https://ref.url", "Python book": "https://amzn.to/xxx"}
AFFILIATE_LINKS={}

# ── Gmail digest alerts ───────────────────────────────────────────────────
GMAIL_USER=alreadyherellc@gmail.com
ALERT_EMAIL=stephen47@gmail.com
# Variable: GMAIL_APP_PASSWORD  (set in server .env, not here)

# ── Telegram daily digest (07:00 UTC) ─────────────────────────────────────
# 1. Create a bot via @BotFather → copy the token
# 2. Send your bot any message (e.g. /start) to open the chat
# 3. Find your chat-ID:
#      docker compose exec -T runtime python -m runtime.agent_impls.daily_digest --get-chat-id
# Variables: TELEGRAM_BOT_TOKEN, TELEGRAM_CHAT_ID  (set in server .env + GitHub Secrets, not here)
# Gmail (GMAIL_USER / GMAIL_APP_PASSWORD / ALERT_EMAIL above) is used as fallback if Telegram fails.
