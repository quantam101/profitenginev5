FROM node:20-alpine AS deps
WORKDIR /app
COPY package.json ./
RUN npm install

FROM node:20-alpine AS build
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .
RUN npm run build

FROM node:20-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
COPY --from=build /app/package.json ./package.json
COPY --from=build /app/package-lock.json ./package-lock.json
COPY --from=build /app/node_modules ./node_modules
COPY --from=build /app/.next ./.next
COPY --from=build /app/public ./public
# Config files required by the health-check endpoint (buildHealthPayload reads these)
COPY --from=build /app/eaos.config.yaml ./eaos.config.yaml
COPY --from=build /app/vercel.json ./vercel.json
COPY --from=build /app/app/api/health ./app/api/health
COPY --from=build /app/agents ./agents
COPY --from=build /app/connectors ./connectors
COPY --from=build /app/observability ./observability
COPY --from=build /app/Dockerfile.web ./Dockerfile.web
COPY --from=build /app/docker-compose.yml ./docker-compose.yml
COPY --from=build /app/.env.example ./.env.example
COPY --from=build /app/.github/workflows/ci.yml ./.github/workflows/ci.yml
EXPOSE 3000
CMD ["npm", "run", "start"]
