# Bare-IP health probe — CI and monitoring can hit http://129.146.167.73/health
# without needing a TLS cert or DNS. Caddy handles this on port 80 only.
# NOTE: the catch-all redir MUST be inside a handle {} block so Caddy treats it
# as "else" — a bare redir fires before handle matches in Caddy v2.
:80 {
  handle /health {
    respond `{"ok":true,"caddy":"up"}` 200
  }
  handle {
    redir https://{host}{uri} 308
  }
}

{$SITE_DOMAIN}, www.{$SITE_DOMAIN} {
  encode gzip zstd
  reverse_proxy web:3000

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    X-Frame-Options "DENY"
    Referrer-Policy "strict-origin-when-cross-origin"
    Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
  }
}

app.{$SITE_DOMAIN} {
  encode gzip zstd
  reverse_proxy web:3000

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    X-Frame-Options "DENY"
    Referrer-Policy "strict-origin-when-cross-origin"
    Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
  }
}

