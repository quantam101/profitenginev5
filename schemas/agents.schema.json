{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["agents"],
  "additionalProperties": false,
  "properties": {
    "agents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "version", "mission", "max_cost_usd", "allowed_connectors", "forbidden_actions", "approval_required_actions", "verifier_required"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "version": { "type": "string", "minLength": 1 },
          "mission": { "type": "string", "minLength": 1 },
          "max_cost_usd": { "type": "number", "maximum": 0 },
          "allowed_connectors": { "type": "array", "items": { "type": "string" } },
          "forbidden_actions": { "type": "array", "items": { "type": "string" } },
          "approval_required_actions": { "type": "array", "items": { "type": "string" } },
          "verifier_required": { "type": "boolean" }
        }
      }
    }
  }
}
